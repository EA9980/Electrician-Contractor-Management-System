<!DOCTYPE html>
<html>
<head>
    <title>Materials Management</title>
    <style>
        body {
            font-family: Arial;
            margin: 20px;
            background: #f4f4f4;
        }

        h2 {
            text-align: center;
        }

        .container {
            width: 80%;
            margin: auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px gray;
        }

        .form-container {
            text-align: center;
            margin-bottom: 20px;
        }

        input {
            padding: 10px;
            margin: 5px;
            width: 20%;
        }

        button {
            padding: 10px 15px;
            margin: 5px;
            border: none;
            color: white;
            cursor: pointer;
            border-radius: 5px;
        }

        .add-btn {
            background-color: green;
        }

        .delete-btn {
            background-color: red;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 10px;
            border: 1px solid #ddd;
            text-align: center;
        }

        th {
            background-color: #333;
            color: white;
        }
    </style>
</head>

<body>

<div class="container">
    <h2>Materials Management</h2>

    <div class="form-container">
        <input type="text" id="name" placeholder="Material Name">
        <input type="number" id="quantity" placeholder="Quantity">
        <input type="text" id="usage" placeholder="Usage">
        <button class="add-btn" onclick="addMaterial()">Add</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Quantity</th>
                <th>Usage</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="materialTable"></tbody>
    </table>
</div>

<script>
    let materials = JSON.parse(localStorage.getItem("materials")) || [];

    function saveData() {
        localStorage.setItem("materials", JSON.stringify(materials));
    }

    function displayMaterials() {
        const table = document.getElementById("materialTable");
        table.innerHTML = "";

        materials.forEach((mat, index) => {
            table.innerHTML += `
                <tr>
                    <td>${mat.name}</td>
                    <td>${mat.quantity}</td>
                    <td>${mat.usage}</td>
                    <td>
                        <button class="delete-btn" onclick="deleteMaterial(${index})">Delete</button>
                    </td>
                </tr>
            `;
        });
    }

    function addMaterial() {
        const name = document.getElementById("name").value;
        const quantity = document.getElementById("quantity").value;
        const usage = document.getElementById("usage").value;

        if (name === "" || quantity === "" || usage === "") {
            alert("Please fill all fields");
            return;
        }

        materials.push({ name, quantity, usage });
        saveData();
        displayMaterials();

        document.getElementById("name").value = "";
        document.getElementById("quantity").value = "";
        document.getElementById("usage").value = "";
    }

    function deleteMaterial(index) {
        materials.splice(index, 1);
        saveData();
        displayMaterials();
    }

    displayMaterials();
</script>

</body>
</html>
