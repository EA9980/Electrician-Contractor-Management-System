<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Profile</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
        }

        .navbar {
            background-color: #2c3e50;
            color: white;
            padding: 15px;
            text-align: center;
            font-size: 20px;
        }

        .container {
            width: 40%;
            margin: 50px auto;
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px rgba(0,0,0,0.1);
        }

        .profile-title {
            text-align: center;
            margin-bottom: 20px;
            color: #333;
        }

        .profile-item {
            margin: 15px 0;
            font-size: 16px;
        }

        .label {
            font-weight: bold;
            color: #555;
        }

        .logout-btn {
            display: block;
            width: 100%;
            padding: 10px;
            background-color: #e74c3c;
            color: white;
            border: none;
            border-radius: 5px;
            margin-top: 25px;
            cursor: pointer;
            font-size: 16px;
        }

        .logout-btn:hover {
            background-color: #c0392b;
        }
    </style>
</head>
<body>

    <div class="navbar">
        Electrician Contractor Management System
    </div>

    <div class="container">
        <h2 class="profile-title">Admin Profile</h2>

        <div class="profile-item">
            <span class="label">Name:</span> Admin User
        </div>

        <div class="profile-item">
            <span class="label">Email:</span> admin@gmail.com
        </div>

        <div class="profile-item">
            <span class="label">Phone:</span> 9876543210
        </div>

        <div class="profile-item">
            <span class="label">Role:</span> System Administrator
        </div>

        <button class="logout-btn" onclick="logout()">Logout</button>
    </div>

    <script>
        function logout() {
            alert("Logging out...");
            // Redirect to login page
            window.location.href = "login.html";
        }
    </script>

</body>
</html>
