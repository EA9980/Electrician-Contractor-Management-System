<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Reports Page - ECMS</title>
    <style>
        body {
            font-family: Arial;
            margin: 0;
            background-color: #f4f6f9;
        }

        header {
            background-color: #2c3e50;
            color: white;
            padding: 15px;
            text-align: center;
        }

        .container {
            padding: 20px;
        }

        .cards {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .card {
            flex: 1;
            padding: 20px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            text-align: center;
        }

        .card h2 {
            margin: 0;
            color: #3498db;
        }

        button {
            padding: 10px 20px;
            background: #27ae60;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        button:hover {
            background: #219150;
        }

        table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
            background: white;
        }

        th, td {
            padding: 10px;
            border: 1px solid #ddd;
            text-align: center;
        }

        th {
            background-color: #34495e;
            color: white;
        }
    </style>
</head>
<body>

<header>
    <h1>Reports Page</h1>
</header>

<div class="container">

    <!-- Summary Cards -->
    <div class="cards">
        <div class="card">
            <h2 id="materials">0</h2>
            <p>Total Materials Used</p>
        </div>

        <div class="card">
            <h2 id="workers">0</h2>
            <p>Total Workers</p>
        </div>

        <div class="card">
            <h2 id="tasks">0</h2>
            <p>Tasks Completed</p>
        </div>
    </div>

    <!-- Generate Report Button -->
    <button onclick="generateReport()">Generate Report</button>

    <!-- Report Table -->
    <table id="reportTable" style="display:none;">
        <thead>
            <tr>
                <th>Material</th>
                <th>Quantity Used</th>
                <th>Worker</th>
                <th>Task</th>
            </tr>
        </thead>
        <tbody id="reportBody"></tbody>
    </table>

</div>

<script>
    function generateReport() {
        // Sample Data (you can connect backend later)
        let data = [
            { material: "Wires", qty: 50, worker: "Ravi", task: "Wiring" },
            { material: "Switches", qty: 30, worker: "Amit", task: "Installation" },
            { material: "Bulbs", qty: 20, worker: "Suresh", task: "Lighting" }
        ];

        // Update summary
        document.getElementById("materials").innerText = 100;
        document.getElementById("workers").innerText = 3;
        document.getElementById("tasks").innerText = 3;

        // Fill table
        let tableBody = document.getElementById("reportBody");
        tableBody.innerHTML = "";

        data.forEach(item => {
            let row = `
                <tr>
                    <td>${item.material}</td>
                    <td>${item.qty}</td>
                    <td>${item.worker}</td>
                    <td>${item.task}</td>
                </tr>
            `;
            tableBody.innerHTML += row;
        });

        document.getElementById("reportTable").style.display = "table";
    }
</script>

</body>
</html>
